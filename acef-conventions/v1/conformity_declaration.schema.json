{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.ai/schemas/v1/conformity_declaration.schema.json",
  "title": "ACEF Conformity Declaration Payload",
  "description": "Payload schema for conformity_declaration records. Captures formal compliance declarations per EU AI Act Art. 47-48, including declarations of conformity, notified body assessments, and certification references.",
  "type": "object",
  "required": ["declaration_type", "declaration_date", "scope"],
  "properties": {
    "declaration_type": {
      "type": "string",
      "description": "Type of conformity declaration.",
      "enum": [
        "eu_declaration_of_conformity",
        "self_assessment",
        "third_party_assessment",
        "notified_body_assessment",
        "quality_management_system_certification",
        "type_examination",
        "other"
      ]
    },
    "declaration_date": {
      "type": "string",
      "description": "Date the declaration was made (ISO 8601).",
      "format": "date"
    },
    "scope": {
      "type": "string",
      "description": "Scope of the conformity declaration — what system(s) and regulation(s) it covers."
    },
    "declarant": {
      "type": "object",
      "description": "Entity making the declaration.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the declaring entity."
        },
        "address": {
          "type": "string",
          "description": "Address of the declaring entity."
        },
        "authorized_representative": {
          "type": "string",
          "description": "Name of the authorized representative."
        }
      },
      "additionalProperties": true
    },
    "notified_body": {
      "type": "object",
      "description": "Notified body involved in the assessment (if applicable).",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the notified body."
        },
        "identification_number": {
          "type": "string",
          "description": "Notified body identification number."
        },
        "assessment_date": {
          "type": "string",
          "format": "date",
          "description": "Date of the notified body's assessment."
        }
      },
      "additionalProperties": true
    },
    "certificate_reference": {
      "type": "string",
      "description": "Reference number of the conformity certificate."
    },
    "certificate_expiry_date": {
      "type": ["string", "null"],
      "description": "Expiry date of the conformity certificate (ISO 8601). Null if no expiry.",
      "format": "date"
    },
    "applicable_regulations": {
      "type": "array",
      "description": "Regulations and standards the declaration covers.",
      "items": {
        "type": "object",
        "properties": {
          "regulation": {
            "type": "string",
            "description": "Name or identifier of the regulation."
          },
          "provisions": {
            "type": "array",
            "description": "Specific provisions covered.",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "harmonised_standards_applied": {
      "type": "array",
      "description": "Harmonised standards applied for conformity assessment.",
      "items": {
        "type": "object",
        "properties": {
          "standard_id": {
            "type": "string",
            "description": "Standard identifier (e.g., 'EN ISO/IEC 42001:2023')."
          },
          "version": {
            "type": "string",
            "description": "Version of the standard."
          },
          "scope_of_application": {
            "type": "string",
            "description": "How the standard was applied."
          }
        },
        "additionalProperties": true
      }
    },
    "conformity_assessment_procedure": {
      "type": "string",
      "description": "Conformity assessment procedure followed (e.g., 'internal_control', 'quality_management_system', 'type_examination')."
    },
    "conditions_of_validity": {
      "type": "array",
      "description": "Conditions under which the declaration remains valid.",
      "items": {
        "type": "string"
      }
    },
    "previous_declaration_ref": {
      "type": "string",
      "description": "Reference to a previous declaration that this one supersedes."
    },
    "supplementary_information": {
      "type": "string",
      "description": "Any supplementary information about the declaration."
    },
    "signatory": {
      "type": "object",
      "description": "Person who signed the declaration.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Signatory name."
        },
        "title": {
          "type": "string",
          "description": "Signatory title or role."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of signing."
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
